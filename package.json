{
  "name": "four-color-root",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "build": "npm --prefix server run build && npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "e2e": "npm run build && playwright test",
    "e2e:headed": "npm run build && playwright test --headed",
    "install:all": "npm install --prefix server && npm install --prefix client",
    "compose:dev": "docker compose -f docker-compose.dev.yml up --build",
    "compose:prod": "docker compose up --build -d",
    "compose:down": "docker compose down",
    "compose:down:dev": "docker compose -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "concurrently": "^9.2.1",
    "start-server-and-test": "^2.1.2",
    "wait-on": "^8.0.5"
  }
}
