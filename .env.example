# Image and package mirrors.
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# Frontend backend endpoints.
# Leave empty for local npm dev or standalone Docker on the same host.
# For Traefik/HTTPS deployment, set these to the public backend origin.
# Examples:
# VITE_SERVER_URL=wss://api.example.com
# VITE_SERVER_HTTP_URL=https://api.example.com
VITE_SERVER_URL=
VITE_SERVER_HTTP_URL=

# Server runtime settings.
REDIS_URL=redis://redis:6379
MIN_PLAYERS=1
BOT_THINK_MIN_MS=1800
BOT_THINK_MAX_MS=3200
LOCAL_TRANSITION_DELAY_MS=5000
ROOM_LOG=1
HU_LOG=1
ROOM_STATE_LOG_MODE=compact

# Traefik deployment.
# Only used by docker-compose.traefik.yml.
TRAEFIK_NETWORK=traefik-global-proxy
TRAEFIK_CERT_RESOLVER=tencentcloud
TRAEFIK_WEB_ROUTER=sise-web
TRAEFIK_SERVER_ROUTER=sise-server
# Values must be valid Traefik rules.
# TRAEFIK_WEB_RULE=Host(`sise.example.com`)
# TRAEFIK_SERVER_RULE=Host(`sise-api.example.com`)
